---
import type { Lang } from '../i18n/ui';
import { getTranslations } from '../i18n/utils';
import banner from '../assets/banner.svg?raw';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getTranslations(lang);
---
<section class="hero-section d-flex align-items-center min-vh-100" style="padding-top: 80px;">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <div class="hero-content">
          <h1 class="display-3 fw-bold mb-4">
            <span class="text-primary">RAG</span>{t.hero.titleSuffix}
            <br />
            <span class="text-gradient">{t.hero.subtitle}</span>
          </h1>
          <p class="lead mb-4 text-muted">{t.hero.description}</p>
          <div class="d-flex flex-wrap gap-3">
            <a class="btn btn-primary btn-lg px-4 py-3" href="#contact">
              <i class="fas fa-rocket me-2"></i>{t.hero.getDemo}
            </a>
            <a class="btn btn-outline-primary btn-lg px-4 py-3" href="#services">
              <i class="fas fa-arrow-right me-2"></i>{t.hero.learnMore}
            </a>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="hero-visual text-center">
          <div class="position-relative">
            <div class="hero-banner rounded-3 shadow-lg" set:html={banner}></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    background: linear-gradient(135deg, var(--bs-light) 0%, var(--bs-white) 100%);
  }
  :global([data-bs-theme="dark"]) .hero-section {
    background: linear-gradient(135deg, var(--bs-dark) 0%, var(--bs-secondary) 100%);
  }
  .text-gradient {
    background: linear-gradient(45deg, #007bff, #6610f2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-banner :global(svg) {
    max-height: 400px;
    width: 100%;
    height: auto;
  }
</style>
