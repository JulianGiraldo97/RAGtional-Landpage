---
import type { Lang } from '../i18n/ui';
import Navbar from './Navbar.astro';
import Hero from './Hero.astro';
import SocialProof from './SocialProof.astro';
import Solutions from './Solutions.astro';
import Services from './Services.astro';
import Technology from './Technology.astro';
import UseCases from './UseCases.astro';
import FAQ from './FAQ.astro';
import Contact from './Contact.astro';
import Footer from './Footer.astro';
import PrivacyModal from './legal/PrivacyModal.astro';
import TermsModal from './legal/TermsModal.astro';
import CookiesModal from './legal/CookiesModal.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
---
<div class="App">
  <Navbar lang={lang} />
  <main>
    <Hero lang={lang} />
    <SocialProof lang={lang} />
    <Solutions lang={lang} />
    <Services lang={lang} />
    <Technology lang={lang} />
    <UseCases lang={lang} />
    <FAQ lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
  <PrivacyModal lang={lang} />
  <TermsModal lang={lang} />
  <CookiesModal lang={lang} />
</div>
