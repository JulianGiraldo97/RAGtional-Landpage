---
import type { Lang } from '../i18n/ui';
import { getTranslations } from '../i18n/utils';
import InfoModal from './InfoModal.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getTranslations(lang);

const cases = [
  { key: 'knowledgeAssistant', icon: 'fas fa-users-cog', ...t.useCases.cases.knowledgeAssistant },
  { key: 'customerSupport', icon: 'fas fa-headset', ...t.useCases.cases.customerSupport },
  { key: 'dataAnalysis', icon: 'fas fa-chart-line', ...t.useCases.cases.dataAnalysis },
];
---
<section id="use-cases" class="py-5">
  <div class="container">
    <div class="row text-center mb-5">
      <div class="col-lg-8 mx-auto">
        <h2 class="display-5 fw-bold mb-3">{t.useCases.title}</h2>
        <p class="lead text-muted">{t.useCases.description}</p>
      </div>
    </div>

    <div class="row">
      {cases.map((c) => (
        <div class="col-lg-4 mb-4">
          <div class="use-case-card h-100 border-0 rounded-3 shadow-sm">
            <div class="card-body p-4">
              <div class="use-case-header mb-4">
                <div class="use-case-icon mb-3">
                  <i class={`${c.icon} fa-2x text-primary`}></i>
                </div>
                <span class="badge bg-primary-subtle text-primary">{c.industry}</span>
              </div>

              <h4 class="fw-bold mb-3">{c.title}</h4>
              <p class="text-muted mb-4">{c.description}</p>

              <h6 class="fw-bold mb-3">{t.useCases.keyBenefits}</h6>
              <ul class="list-unstyled">
                {c.benefits.map((benefit) => (
                  <li class="mb-2 d-flex align-items-start">
                    <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                    <span>{benefit}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="card-footer bg-transparent border-0 p-4 pt-0">
              <button
                type="button"
                class="btn btn-outline-primary w-100"
                data-bs-toggle="modal"
                data-bs-target={`#useCaseModal-${c.key}`}
              >
                <i class="fas fa-arrow-right me-2"></i>{t.useCases.learnMore}
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="row mt-5">
      <div class="col-12 text-center">
        <div class="cta-section p-5 rounded-3">
          <h3 class="fw-bold mb-3">{t.useCases.cta.title}</h3>
          <p class="text-muted mb-4">{t.useCases.cta.description}</p>
          <div class="d-flex justify-content-center flex-wrap gap-3">
            <a class="btn btn-primary btn-lg px-4 py-3" href="#contact">
              <i class="fas fa-rocket me-2"></i>{t.useCases.cta.startJourney}
            </a>
            <a class="btn btn-outline-primary btn-lg px-4 py-3" href="#contact">
              <i class="fas fa-comments me-2"></i>{t.useCases.cta.scheduleDemo}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  {cases.map((c) => (
    <InfoModal
      id={`useCaseModal-${c.key}`}
      lang={lang}
      title={c.title}
      description={c.detailedDescription}
      icon={c.icon}
      features={c.benefits}
      ctaText={t.useCases.getStarted}
    />
  ))}
</section>

<style>
  .use-case-card {
    background: var(--bs-white);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }
  .use-case-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 123, 255, 0.15) !important;
  }
  .use-case-icon {
    width: 70px;
    height: 70px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(0, 123, 255, 0.1), rgba(102, 16, 242, 0.1));
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .use-case-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .cta-section {
    background: linear-gradient(135deg, rgba(0, 123, 255, 0.05), rgba(102, 16, 242, 0.05));
    border: 1px solid rgba(0, 123, 255, 0.1);
  }
  :global([data-bs-theme="dark"]) .use-case-card {
    background: var(--bs-dark);
    color: var(--bs-light);
    border-color: rgba(255, 255, 255, 0.1);
  }
  :global([data-bs-theme="dark"]) .use-case-icon {
    background: linear-gradient(135deg, rgba(0, 123, 255, 0.2), rgba(102, 16, 242, 0.2));
  }
  :global([data-bs-theme="dark"]) .cta-section {
    background: linear-gradient(135deg, rgba(0, 123, 255, 0.1), rgba(102, 16, 242, 0.1));
    border-color: rgba(0, 123, 255, 0.2);
  }
</style>
